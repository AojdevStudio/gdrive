{
  "name": "@modelcontextprotocol/server-gdrive",
  "version": "4.0.0-alpha",
  "description": "Private remote AOJ Workbench MCP server for Composio-backed knowledge-work toolkits over Cloudflare Workers HTTP",
  "license": "MIT",
  "author": "Anthropic, PBC (https://anthropic.com)",
  "homepage": "https://modelcontextprotocol.io",
  "bugs": "https://github.com/modelcontextprotocol/servers/issues",
  "type": "module",
  "files": [
    "dist-worker",
    "worker.ts",
    "wrangler.toml"
  ],
  "scripts": {
    "build": "tsc && shx chmod +x dist/*.js",
    "prepare": "npm run build && npm run build:worker",
    "watch": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --testMatch='**/__tests__/integration/**/*.test.ts'",
    "test:e2e": "jest --testMatch='**/tests/e2e/**/*.test.ts'",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "bmad:refresh": "bmad-method install -f -i codex",
    "bmad:list": "bmad-method list:agents",
    "bmad:validate": "bmad-method validate",
    "build:worker": "tsc -p tsconfig.worker.json",
    "dev:worker": "wrangler dev",
    "deploy:worker": "wrangler deploy",
    "smoke:worker": "node scripts/smoke/remote-worker-smoke.mjs"
  },
  "dependencies": {
    "@composio/core": "^0.10.0",
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@xmldom/xmldom": "^0.9.10",
    "googleapis": "^144.0.0",
    "jszip": "^3.10.1",
    "pdfjs-dist": "^6.0.227",
    "winston": "^3.17.0"
  },
  "overrides": {
    "qs": "^6.15.2",
    "uuid": "^11.1.1"
  },
  "engines": {
    "node": ">=22.13.0 || >=24"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.21.0",
    "jest": "^29.7.0",
    "shx": "^0.3.4",
    "ts-jest": "^29.1.5",
    "typescript": "^5.6.3",
    "wrangler": "^4.95.0"
  }
}
