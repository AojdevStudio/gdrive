# AOJ Workbench Worker environment variables

# Required Worker secrets.
# Keep values out of logs, docs, commits, shell history, and issue comments.
COMPOSIO_API_KEY=
AOJ_WORKBENCH_USER_ID=
MCP_BEARER_TOKEN=

# Local MCP client alias. Use the same value as the deployed Worker's
# MCP_BEARER_TOKEN, but configure clients with this env var name.
AOJ_WORKBENCH_MCP_TOKEN=

# Optional Worker runtime settings.
LOG_LEVEL=info
MCP_ALLOWED_ORIGINS=

# Optional protected-resource metadata for a real external MCP authorization
# server. Metadata only; AOJ Workbench still validates MCP_BEARER_TOKEN.
# Do not set this to a provider OAuth URL.
# MCP_AUTHORIZATION_SERVER_URL=https://auth.example.com

# Cloudflare deployment values for Wrangler/operator workflows.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Cloudflare KV namespace ID for the GDRIVE_KV Worker binding when cache or
# tracking compatibility state is needed.
CLOUDFLARE_KV_NAMESPACE_ID=

# Optional local contributor tooling.
PAI_CONTACTS_PATH=
